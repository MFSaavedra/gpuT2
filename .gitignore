# ----------------------------------------------------------------------------
# Build output
# ----------------------------------------------------------------------------
/build/
build*/
# CLion out-of-source builds
cmake-build-*/
# generated; lives under build/ but often symlinked to root
compile_commands.json

# ----------------------------------------------------------------------------
# CUDA / OpenCL compiler intermediates
# ----------------------------------------------------------------------------
*.i
*.ii
*.gpu
*.ptx
*.cubin
*.fatbin

# ----------------------------------------------------------------------------
# Editor / tooling (keep the tracked .clangd config; ignore only its cache)
# ----------------------------------------------------------------------------
.cache/
.vscode/
.idea/
*.swp

# ----------------------------------------------------------------------------
# Analysis artifacts (results/*.csv are deliverables — do NOT ignore them)
# ----------------------------------------------------------------------------
.ipynb_checkpoints/

# ----------------------------------------------------------------------------
# LaTeX build artifacts (report/). Image PDFs under report/img/ and the
# assignment PDF are tracked, so do NOT blanket-ignore *.pdf.
# ----------------------------------------------------------------------------
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.lof
*.lol
*.log
*.lot
*.nav
*.out
*.run.xml
*.snm
*.synctex.gz
*.toc
*.vrb

# ----------------------------------------------------------------------------
# OS cruft
# ----------------------------------------------------------------------------
.DS_Store
Thumbs.db
