// CUDA backend: the three coordinate spaces and the two maps between them.
// Render (see report "Report" section in CLAUDE.md / Makefile-style commands):
//   dot -Tpdf report/diagrams/cuda_coordinate_spaces.dot -o report/img/cuda_coordinate_spaces.pdf
//   dot -Tpng -Gdpi=200 report/diagrams/cuda_coordinate_spaces.dot -o report/img/cuda_coordinate_spaces.png
digraph cuda_coordinate_spaces {
  rankdir=LR;
  bgcolor="white";
  fontname="Helvetica";
  nodesep=0.6; ranksep=1.1;
  node [shape=box, style="rounded,filled", fillcolor="#f5f5f5",
        fontname="Helvetica", fontsize=11, color="#999999", penwidth=1.2];
  edge [fontname="Helvetica", fontsize=10, color="#333333", penwidth=1.3];

  subgraph cluster_exec {
    label="1.  Execution space\n(how the threads are organised)";
    labelloc="t"; labeljust="l";
    fontname="Helvetica-Bold"; fontsize=12; fontcolor="#33557a";
    style="rounded,filled"; color="#9bbbdc"; fillcolor="#eef4fb";
    exec [label="block (blockIdx.x, blockIdx.y)\nblockDim = (32, by)\nthread (threadIdx.x, threadIdx.y)",
          fillcolor="#dce8f5", color="#6f9bcb"];
  }

  subgraph cluster_board {
    label="2.  Board space\n(rows x cols, 2-D logical grid)";
    labelloc="t"; labeljust="l";
    fontname="Helvetica-Bold"; fontsize=12; fontcolor="#2f7a5d";
    style="rounded,filled"; color="#8fc9b0"; fillcolor="#eef7f2";
    board [label="cell (row, col)", fillcolor="#d6efe3", color="#5aa987"];
  }

  subgraph cluster_mem {
    label="3.  Memory space\n(flat 1-D array, row-major)";
    labelloc="t"; labeljust="l";
    fontname="Helvetica-Bold"; fontsize=12; fontcolor="#9a6a2f";
    style="rounded,filled"; color="#d8b483"; fillcolor="#fbf3ea";
    mem [label="src[ offset ]", fillcolor="#f5e3cd", color="#c79a5a"];
  }

  exec -> board [label="  col = blockIdx.x * 32 + threadIdx.x\l  row = blockIdx.y * by + threadIdx.y\l"];
  board -> mem  [label="  offset = row * cols + col\l"];
}
